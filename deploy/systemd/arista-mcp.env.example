# Sample environment file for the arista-mcp systemd unit.
# Copy to /etc/arista-mcp.env, restrict ownership (root:root, mode 0600),
# and edit per host.
#
#   sudo cp deploy/systemd/arista-mcp.env.example /etc/arista-mcp.env
#   sudo chmod 0600 /etc/arista-mcp.env
#   sudo $EDITOR /etc/arista-mcp.env

# Postgres connection. The DB must already have the arista-mcp schema
# (run `dotnet ef database update --project src/AristaMcp.Data` once)
# and the corpus ingested (`arista-mcp ingest --catalog ...`) or
# restored (`arista-mcp bootstrap --release vX.Y.Z`).
#
# For a host-installed binary connecting to the dockerised PG on the
# default published port:
ARISTA_MCP__CONNECTIONSTRING=Host=127.0.0.1;Port=5434;Database=arista;Username=arista;Password=changeme

# For the Quadlet-deployed server container reaching PG through the
# internal Quadlet network, override with:
#   Host=arista-mcp-postgres;Port=5432

# Where the ONNX models live. The directory must contain `embedder/` and
# `reranker/` subdirectories, populated by scripts/fetch-models.ps1 (or
# unzipped from a release attachment). Defaults to ./models if unset.
ARISTA_MCP__MODELSDIR=/var/lib/arista-mcp/models

# Optional: override the reranker directory for v0.3.0 fine-tune /
# INT8 variants. Leave commented to use ${MODELSDIR}/reranker
# (bge-reranker-v2-m3 INT8, the v0.3.0 default).
# ARISTA_MCP__RERANKERDIR=/var/lib/arista-mcp/models/reranker

# Optional: opt into the HyDE / multi-query / listwise rewriters that
# shipped behind feature flags in v0.3.0. All default to false because
# they regressed top-1 on the v2 bench; toggle on per-experiment.
# ARISTA_MCP__HYDE__ENABLED=true
# ARISTA_MCP__MULTIQUERY__ENABLED=true
# ARISTA_MCP__LISTWISE__ENABLED=true

# Optional: OpenTelemetry endpoint. The MCP server emits
# `AristaMcp` ActivitySource spans; tracing is opt-in.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.internal:4317
# OTEL_EXPORTER_OTLP_PROTOCOL=grpc
